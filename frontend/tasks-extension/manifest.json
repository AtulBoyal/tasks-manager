{
  "manifest_version": 3,
  "name": "Tasks Quick Add",
  "version": "1.0",
  "description": "Quickly add tasks to your Supabase Tasks Manager.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Add Task"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Quick Add Menu"
    }
  }
}